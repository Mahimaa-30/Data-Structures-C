#include <stdio.h>
#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

void enqueue(int x) {
    if(rear == MAX - 1) {
        printf("Overflow\n");
        return;
    }
    if(front == -1) front = 0;
    queue[++rear] = x;
}

void dequeue() {
    if(front == -1 || front > rear) {
        printf("Underflow\n");
        return;
    }
    printf("Deleted: %d\n", queue[front++]);
}

void display() {
    for(int i = front; i <= rear; i++)
        printf("%d ", queue[i]);
}

int main() {
    enqueue(10); enqueue(20);
    dequeue();
    display();
    return 0;
}
