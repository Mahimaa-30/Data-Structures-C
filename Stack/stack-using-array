#include <stdio.h>
#define MAX 5

int stack[MAX];
int top = -1;

void push(int x) {
    if(top == MAX - 1) {
        printf("Overflow\n");
        return;
    }
    stack[++top] = x;
}

void pop() {
    if(top == -1) {
        printf("Underflow\n");
        return;
    }
    printf("Popped: %d\n", stack[top--]);
}

void display() {
    for(int i = top; i >= 0; i--)
        printf("%d\n", stack[i]);
}

int main() {
    push(10); push(20); push(30);
    pop();
    display();
    return 0;
}
